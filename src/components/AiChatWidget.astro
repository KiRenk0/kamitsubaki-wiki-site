---
type AiChatCopy = {
  title: string;
  status: string;
  buttonLabel: string;
  closeLabel: string;
  minimizeLabel: string;
  inputLabel: string;
  inputPlaceholder: string;
  sendLabel: string;
  modelModeLabel: string;
  customModelLabel: string;
  customModelPlaceholder: string;
  thinkingModeLabel: string;
  modelModes: { value: string; label: string }[];
  thinkingModes: { value: string; label: string }[];
  bubbleIdle: string;
  bubbleThinking: string;
  greeting: string;
  fallbackOffline: string;
  emptyResponse: string;
  challengeFallback: string;
  streamErrorFallback: string;
  accountAnonymous: string;
  accountLoggedInPrefix: string;
  githubLoginLabel: string;
  googleLoginLabel: string;
  logoutLabel: string;
  authErrorFallback: string;
  quickPrompts: string[];
};

const { lang = 'zh', copy } = Astro.props as { lang?: string; copy: AiChatCopy };
const normalizedCopy = {
  ...copy,
  modelModeLabel: copy.modelModeLabel ?? 'Model',
  customModelLabel: copy.customModelLabel ?? 'Custom',
  customModelPlaceholder: copy.customModelPlaceholder ?? 'model-id',
  thinkingModeLabel: copy.thinkingModeLabel ?? 'Thinking',
  accountAnonymous: copy.accountAnonymous ?? 'Anonymous observer',
  accountLoggedInPrefix: copy.accountLoggedInPrefix ?? 'Signed in',
  githubLoginLabel: copy.githubLoginLabel ?? 'Continue with GitHub',
  googleLoginLabel: copy.googleLoginLabel ?? 'Continue with Google',
  logoutLabel: copy.logoutLabel ?? 'Sign out',
  authErrorFallback: copy.authErrorFallback ?? 'The auth line is unstable.',
  modelModes: copy.modelModes ?? [
    { value: 'auto', label: 'Auto' },
    { value: 'fast', label: 'Fast' },
    { value: 'balanced', label: 'Balanced' },
    { value: 'deep', label: 'Deep' },
    { value: 'custom', label: 'Custom' },
  ],
  thinkingModes: copy.thinkingModes ?? [
    { value: 'auto', label: 'Auto' },
    { value: 'off', label: 'Off' },
    { value: 'light', label: 'Light' },
    { value: 'deep', label: 'Deep' },
  ],
};
const apiBase = import.meta.env.PUBLIC_AI_OBSERVER_API_BASE || '';
---

<aside
  class="ai-chat fixed bottom-6 right-6 z-50 font-sans"
  data-ai-chat
  data-api-base={apiBase}
  data-locale={lang}
  data-copy={JSON.stringify(normalizedCopy)}
  aria-label={copy.title}
>
  <div class="ai-chat__bubble absolute bottom-16 right-0 mb-2 px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 text-sm rounded-2xl shadow-xl opacity-0 scale-95 pointer-events-none transition-all duration-300 origin-bottom-right" data-ai-bubble aria-hidden="true">{copy.bubbleIdle}</div>
  
  <button class="ai-chat__orb relative flex items-center justify-center w-14 h-14 rounded-full bg-gray-900 dark:bg-white text-white dark:text-gray-900 shadow-2xl transition-transform hover:scale-105 active:scale-95" type="button" data-ai-toggle aria-label={copy.buttonLabel} aria-expanded="false">
    <span class="ai-chat__orb-ring absolute inset-0 rounded-full border-2 border-transparent"></span>
    <span class="ai-chat__orb-core">
      <svg class="w-6 h-6 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
      </svg>
    </span>
  </button>

  <section class="ai-chat__panel absolute bottom-20 right-0 w-[24rem] max-w-[calc(100vw-3rem)] max-h-[80vh] flex flex-col bg-white/85 dark:bg-gray-900/85 backdrop-blur-2xl border border-gray-200/50 dark:border-gray-700/50 shadow-[0_8px_30px_rgb(0,0,0,0.12)] rounded-3xl overflow-hidden transition-all duration-300 opacity-0 scale-95 pointer-events-none origin-bottom-right" data-ai-panel aria-hidden="true">
    
    <header class="ai-chat__header flex items-center justify-between p-5 border-b border-gray-100 dark:border-gray-800">
      <div>
        <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">{copy.status}</p>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white leading-tight">{copy.title}</h2>
      </div>
      <div class="ai-chat__actions flex items-center gap-2">
        <button class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" type="button" data-ai-minimize aria-label={copy.minimizeLabel}>
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14" /></svg>
        </button>
        <button class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" type="button" data-ai-close aria-label={copy.closeLabel}>
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12" /></svg>
        </button>
      </div>
    </header>

    <div class="ai-chat__auth flex flex-col gap-3 p-5 border-b border-gray-100 dark:border-gray-800" data-ai-auth>
      <div class="flex items-center justify-between">
        <p class="text-sm font-medium text-gray-600 dark:text-gray-300" data-ai-auth-status>{normalizedCopy.accountAnonymous}</p>
        <button class="text-xs text-red-500 hover:text-red-600 transition-colors px-2 py-1 rounded hover:bg-red-50 dark:hover:bg-red-950/30" type="button" data-ai-logout hidden>{normalizedCopy.logoutLabel}</button>
      </div>
      <div class="flex flex-col gap-2 ai-chat__auth-actions">
        <button class="group flex items-center justify-center gap-3 w-full py-2.5 px-4 text-sm font-semibold rounded-xl bg-[#24292F] hover:bg-[#1b1f24] text-white transition-all shadow-sm active:scale-[0.98]" type="button" data-ai-oauth="github">
          <svg class="w-5 h-5 group-hover:scale-110 transition-transform" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
          {normalizedCopy.githubLoginLabel}
        </button>
        <button class="group flex items-center justify-center gap-3 w-full py-2.5 px-4 text-sm font-semibold rounded-xl bg-white hover:bg-gray-50 text-gray-700 border border-gray-200 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200 dark:hover:bg-gray-700 transition-all shadow-sm active:scale-[0.98]" type="button" data-ai-oauth="google">
          <svg class="w-5 h-5 group-hover:scale-110 transition-transform" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/><path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/><path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 35.091 26.715 36 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303c-.792 2.237-2.231 4.166-4.087 5.571c.001-.001.002-.001.003-.002l6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/></svg>
          {normalizedCopy.googleLoginLabel}
        </button>
      </div>
      <p class="text-xs text-red-500 mt-1" data-ai-auth-note hidden></p>
    </div>

    <div class="ai-chat__controls flex flex-wrap gap-2 p-4 border-b border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/30" data-ai-controls>
      <label class="flex flex-col gap-1.5 flex-1 min-w-[120px]">
        <span class="text-[11px] font-semibold text-gray-500 uppercase tracking-wider">{normalizedCopy.modelModeLabel}</span>
        <select class="w-full text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg px-2.5 py-1.5 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-shadow appearance-none" data-ai-model-choice aria-label={normalizedCopy.modelModeLabel}>
          {normalizedCopy.modelModes.map((mode) => (
            <option value={mode.value}>{mode.label}</option>
          ))}
        </select>
      </label>
      <label class="ai-chat__custom-model flex flex-col gap-1.5 flex-1 min-w-[120px]" data-ai-custom-model-wrap hidden>
        <span class="text-[11px] font-semibold text-gray-500 uppercase tracking-wider">{normalizedCopy.customModelLabel}</span>
        <input class="w-full text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg px-2.5 py-1.5 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-shadow" data-ai-custom-model type="text" inputmode="text" autocomplete="off" placeholder={normalizedCopy.customModelPlaceholder} />
      </label>
      <label class="flex flex-col gap-1.5 flex-1 min-w-[100px]">
        <span class="text-[11px] font-semibold text-gray-500 uppercase tracking-wider">{normalizedCopy.thinkingModeLabel}</span>
        <select class="w-full text-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg px-2.5 py-1.5 focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-shadow appearance-none" data-ai-thinking-mode aria-label={normalizedCopy.thinkingModeLabel}>
          {normalizedCopy.thinkingModes.map((mode) => (
            <option value={mode.value}>{mode.label}</option>
          ))}
        </select>
      </label>
    </div>

    <div class="ai-chat__messages flex-1 overflow-y-auto p-5 space-y-4 max-h-[40vh]" data-ai-messages role="log" aria-live="polite">
      <article class="ai-message ai-message--assistant flex gap-3 w-full">
        <div class="w-8 h-8 rounded-full bg-gray-900 dark:bg-white flex items-center justify-center shrink-0 shadow-sm">
           <svg class="w-4 h-4 text-white dark:text-gray-900" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        </div>
        <div class="bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200 px-4 py-2.5 rounded-2xl rounded-tl-sm text-sm leading-relaxed prose prose-sm dark:prose-invert">
          <p>{copy.greeting}</p>
        </div>
      </article>
    </div>

    <div class="ai-chat__quick px-5 py-3 flex gap-2 overflow-x-auto scrollbar-hide border-t border-gray-100 dark:border-gray-800" data-ai-quick>
      {copy.quickPrompts.map((prompt) => (
        <button class="shrink-0 text-xs text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 px-3 py-1.5 rounded-full hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors whitespace-nowrap shadow-sm" type="button" data-ai-prompt={prompt}>{prompt}</button>
      ))}
    </div>

    <form class="ai-chat__form p-4 border-t border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900" data-ai-form>
      <label class="sr-only" for="ai-chat-input">{copy.inputLabel}</label>
      <div class="relative flex items-end gap-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-2xl p-1.5 focus-within:ring-2 focus-within:ring-gray-900 dark:focus-within:ring-white transition-shadow shadow-inner">
        <textarea class="w-full bg-transparent resize-none outline-none text-sm text-gray-800 dark:text-gray-200 py-2.5 pl-3 max-h-32 min-h-[44px]" id="ai-chat-input" data-ai-input rows="1" maxlength="5000" placeholder={copy.inputPlaceholder}></textarea>
        <button class="shrink-0 w-9 h-9 flex items-center justify-center rounded-xl bg-gray-900 dark:bg-white text-white dark:text-gray-900 hover:opacity-90 transition-opacity disabled:opacity-50 disabled:cursor-not-allowed mb-1 mr-1" type="submit" data-ai-submit aria-label={copy.sendLabel}>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
        </button>
      </div>
    </form>
  </section>
</aside>

<script>
  import '../scripts/aiChatWidget.js';
</script>
