---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  title?: string;
}

const { headings, title = 'Contents' } = Astro.props as Props;
const visibleHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<nav class="wiki-toc w-full max-h-[calc(100vh-10rem)] overflow-y-auto pr-2 custom-scrollbar" aria-label={title}>
  <div class="mb-4 flex items-center justify-between gap-3">
    <h3 class="text-xs font-mono tracking-widest text-white/40 uppercase">{title}</h3>
    <span class="text-[10px] font-mono text-white/25">{visibleHeadings.length}</span>
  </div>
  {visibleHeadings.length > 0 && (
    <ul class="space-y-1 text-sm font-sans border-l border-white/10 pl-4 toc-list">
      {visibleHeadings.map((heading) => (
        <li class={`heading-level-${heading.depth}`}>
          <a
            href={`#${heading.slug}`}
            class="block rounded-sm py-1.5 pr-2 text-white/55 hover:text-white hover:translate-x-1 transition-all duration-300"
            data-slug={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  )}
</nav>

<script>
  type TocWindow = Window & typeof globalThis & {
    __wikiTocCleanup?: (() => void) | null;
    __wikiTocTrackingBound?: boolean;
  };

  const getAnchorOffset = () => {
    const fixedNav = document.querySelector<HTMLElement>('nav.fixed');
    const navHeight = fixedNav?.getBoundingClientRect().height ?? 72;

    return Math.ceil(navHeight + 32);
  };

  function setupToCTracking() {
    const tocWindow = window as TocWindow;

    if (tocWindow.__wikiTocCleanup) {
      tocWindow.__wikiTocCleanup();
      tocWindow.__wikiTocCleanup = null;
    }

    const headings = Array.from(document.querySelectorAll<HTMLElement>('h2[id], h3[id]'));
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-list a[data-slug]'));

    if (headings.length === 0 || links.length === 0) {
      return;
    }

    const setActiveSlug = (slug: string | null) => {
      links.forEach((link) => {
        const isActive = link.dataset.slug === slug;
        link.dataset.active = isActive ? 'true' : 'false';
      });
    };

    const syncActiveHeading = () => {
      const offset = getAnchorOffset();
      let activeSlug = headings[0].getAttribute('id');

      for (const heading of headings) {
        if (heading.getBoundingClientRect().top - offset <= 0) {
          activeSlug = heading.getAttribute('id');
        } else {
          break;
        }
      }

      if (activeSlug) {
        setActiveSlug(activeSlug);
      }
    };

    const scrollToHeading = (event: MouseEvent) => {
      const link = event.currentTarget;

      if (!(link instanceof HTMLAnchorElement)) {
        return;
      }

      const slug = link.dataset.slug;
      const target = slug ? document.getElementById(slug) : null;

      if (!slug || !target) {
        return;
      }

      event.preventDefault();

      const top = Math.max(target.getBoundingClientRect().top + window.scrollY - getAnchorOffset(), 0);
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      setActiveSlug(slug);
      window.history.pushState(null, '', `${window.location.pathname}${window.location.search}#${slug}`);
      window.scrollTo({
        top,
        behavior: prefersReducedMotion ? 'auto' : 'smooth',
      });
    };

    let ticking = false;
    const requestSync = () => {
      if (ticking) {
        return;
      }

      ticking = true;
      window.requestAnimationFrame(() => {
        syncActiveHeading();
        ticking = false;
      });
    };

    requestSync();
    links.forEach((link) => link.addEventListener('click', scrollToHeading));
    window.addEventListener('scroll', requestSync, { passive: true });
    window.addEventListener('resize', requestSync);
    window.addEventListener('hashchange', requestSync);

    tocWindow.__wikiTocCleanup = () => {
      links.forEach((link) => link.removeEventListener('click', scrollToHeading));
      tocWindow.removeEventListener('scroll', requestSync);
      tocWindow.removeEventListener('resize', requestSync);
      tocWindow.removeEventListener('hashchange', requestSync);
    };
  }

  const tocWindow = window as TocWindow;

  if (!tocWindow.__wikiTocTrackingBound) {
    tocWindow.__wikiTocTrackingBound = true;
    document.addEventListener('astro:page-load', setupToCTracking);
  }

  setupToCTracking();
</script>

<style>
  .heading-level-3 {
    margin-left: 1rem;
    font-size: 0.85em;
  }
</style>
